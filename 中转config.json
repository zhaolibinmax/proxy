{
  "log": {
    "loglevel": "warning",
    "access": "/var/log/xray/access.log",
    "error": "/var/log/xray/error.log"
    },
  "inbounds": [
    {
      "listen": "127.0.0.1",
      "port": 10808,
      "protocol": "socks"
    },
    {
      "listen": "127.0.0.1",
      "port": 10809,
      "protocol": "http"
    },
    {
      "listen": "0.0.0.0",
            "port": 1234,
            "protocol": "vmess",
            "settings": {
                "clients": [
                    {
                        "id": "xxxxx"
                    }
                ]
            },
            "streamSettings": {
                "network": "tcp"
            }
        }
    ],
  "outbounds": [
    {
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "xxxxx",
            "port": 443,
            "users": [
              {
                "id": "xxxxx",
                "encryption": "none"
              }
            ]
          }
        ]
      },
      "tag": "PROXY:XHTTP+TLS",
      "streamSettings": {
        "network": "xhttp",
        "security": "tls",
        "tlsSettings": {
          "serverName": "xxxxx",
          "allowInsecure": false,
          "alpn": ["h2"],
          "fingerprint": "chrome"
        },
        "xhttpSettings": {
          "host": "xxxxx",
          "path": "/xxxxx",
          "mode": "auto"
        }
      }
    }
  ]

}

